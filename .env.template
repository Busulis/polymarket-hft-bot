# ============================================================
# Polymarket BTC Trading Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
# ============================================================

# --- Wallet & Authentication ---
# Your Polygon wallet private key (hex, with or without 0x prefix)
POLYGON_PRIVATE_KEY=

# Polymarket CLOB API credentials (from create_or_derive_api_creds)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASS=

# --- Market Selection ---
# "BTC-5" for 5-minute markets, "BTC-15" for 15-minute markets
DEFAULT_MARKET=BTC-5

# --- Trade Parameters ---
# Fraction of USDC balance per trade (0.10 = 10%)
TRADE_AMOUNT_PERCENT=0.10

# Stop-loss threshold (0.05 = 5% loss triggers auto-sell)
STOP_LOSS_PERCENT=0.05

# Max price offset from top-of-book for limit orders (0.02 = 2 cents)
MAX_SLIPPAGE_PERCENT=0.02

# --- Safety ---
# Set to true to simulate orders without sending to chain
DRY_RUN=true
